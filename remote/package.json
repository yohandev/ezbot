{
  "name": "ezbot-remote",
  "version": "1.0.0",
  "description": "Remote control & upload service for the ezbot platform",
  "main": "index.js",
  "author": "Yohan Guyomard",
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.js --outfile=www/index.js --bundle --minify --sourcemap --target=chrome58,firefox57,safari11,edge16 --loader:.py=file --loader:.bin=file",
    "serve": "yarn build --watch --serve --servedir=www"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  },
  "dependencies": {
    "jquery": "^4.0.0"
  }
}
